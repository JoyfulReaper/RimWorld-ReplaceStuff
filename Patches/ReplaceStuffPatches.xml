<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <!-- Base Attribute Patches -->
    <Operation Class="PatchOperationAttributeAdd">
        <xpath>Defs/ThingDef[defName="Cooler"]</xpath>
        <attribute>Name</attribute>
        <value>Cooler</value>
        <success>Always</success>
    </Operation>
    
    <Operation Class="PatchOperationAttributeAdd">
        <xpath>Defs/ThingDef[defName="Vent"]</xpath>
        <attribute>Name</attribute>
        <value>Vent</value>
        <success>Always</success>
    </Operation>

    <!-- Door/Autodoor Patch -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Door"]/building/relatedBuildCommands</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Door"]/building</xpath>
            <value>
                <relatedBuildCommands />
            </value>
        </nomatch>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Door"]/building/relatedBuildCommands</xpath>
        <value>
            <li>Autodoor</li>
        </value>
    </Operation>

    <!-- Designator and Over-Wall Building Patches -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/DesignationCategoryDef[defName="Structure"]/specialDesignatorClasses</xpath>
        <value>
            <li>Replace_Stuff.Replace.Designator_ReplaceStuff</li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Wall"]/building/relatedBuildCommands</xpath>
        <value>
            <li>Cooler_Over</li>
            <li>Cooler_Over2W</li>
            <li>Vent_Over</li>
        </value>
    </Operation>

</Patch>